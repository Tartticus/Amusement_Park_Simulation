create or replace  temporary view AMUSEMENTPARK.GOLD.fact_ticket_sale__dbt_tmp
  
   as (
    

with silver as (

    select *
    from AMUSEMENTPARK.CORE.stg_ticket_sales

    
        where loaded_at > (select max(event_timestamp) from AMUSEMENTPARK.GOLD.fact_ticket_sale)
    

),

with_dims as (

    select
        s.event_id,
        s.order_id,
        s.guest_id,
        p.park_id,
        t.ticket_type_id,
        d.date_id,
        s.event_hour,
        s.quantity,
        s.unit_price,
        s.total_price,
        s.payment_method,
        s.channel,
        s.event_timestamp,
        s.loaded_at,
        s.s3_file_name

    from silver s
    join AMUSEMENTPARK.GOLD.DIM_PARK p
        on p.park_name = s.park
    join AMUSEMENTPARK.GOLD.DIM_TICKET_TYPE t
        on t.ticket_name = s.ticket_type
    join AMUSEMENTPARK.GOLD.DIM_DATE d
        on d.full_date = s.event_date

)

select * from with_dims
  );
